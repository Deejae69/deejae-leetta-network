# Environment configuration for DeeJae LeEtta Network
# Copy this file to .env and fill in your values

# Logging
LOG_LEVEL=INFO

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR-PROJECT-ID
D33J_TOKEN_ADDRESS=
PRIVATE_KEY=

# AI API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Trading Configuration
TRADING_MODE=paper
RISK_TOLERANCE=0.02
MAX_POSITION_SIZE=0.5
STOP_LOSS_PERCENTAGE=0.05
TAKE_PROFIT_PERCENTAGE=0.15

# Webhook Configuration
WEBHOOK_SECRET=your-secret-key-here
WEBHOOK_PORT=8080

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False

# Environment: development | staging | production
ENVIRONMENT=development

# JWT Authentication
# IMPORTANT: Set a strong, random secret in production (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# Admin users (comma-separated usernames)
ADMIN_USERS=admin
# Per-user password hash: generate with scripts/hash_password.py
# Format: ADMIN_PASSWORD_HASH_<UPPERCASE_USERNAME>=<pbkdf2-sha256 hash>
ADMIN_PASSWORD_HASH_ADMIN=

# MFA (TOTP) - set True to require MFA for admin logins
MFA_REQUIRED=False
# Per-user TOTP secret: generate with pyotp.random_base32()
# Format: ADMIN_TOTP_SECRET_<UPPERCASE_USERNAME>=<base32 secret>
ADMIN_TOTP_SECRET_ADMIN=

# Database
DATABASE_URL=sqlite:///deejae_network.db

# External Integrations
GITHUB_TOKEN=
TWITTER_API_KEY=
DISCORD_WEBHOOK_URL=

# Campaign Tracking
TRACK_CAMPAIGNS=True
CAMPAIGN_CHECK_INTERVAL=3600
