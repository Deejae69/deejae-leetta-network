# Environment configuration for DeeJae LeEtta Network
# Copy this file to .env and fill in your values

# Logging
LOG_LEVEL=INFO

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR-PROJECT-ID
D33J_TOKEN_ADDRESS=
PRIVATE_KEY=

# AI API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Trading Configuration
TRADING_MODE=paper
RISK_TOLERANCE=0.02
MAX_POSITION_SIZE=0.5
STOP_LOSS_PERCENTAGE=0.05
TAKE_PROFIT_PERCENTAGE=0.15

# Webhook Configuration
WEBHOOK_SECRET=your-secret-key-here
WEBHOOK_PORT=8080

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False

# Database
DATABASE_URL=sqlite:///deejae_network.db

# External Integrations
GITHUB_TOKEN=
TWITTER_API_KEY=
DISCORD_WEBHOOK_URL=

# Campaign Tracking
TRACK_CAMPAIGNS=True
CAMPAIGN_CHECK_INTERVAL=3600
